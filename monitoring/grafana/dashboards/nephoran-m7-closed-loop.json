{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "heatmap",
      "name": "Heatmap",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "End-to-end visibility for the Nephoran M7 closed-loop pipeline: E2 KPM observe, LLM analyze, intent plan, GitOps execute.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Active Intents",
      "description": "Number of intents currently in-flight in the pipeline.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 5 },
              { "color": "#F2495C", "value": 10 }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "nephoran_active_intents",
          "legendFormat": "Active",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Intents Created",
      "description": "Cumulative count of intents created across all sources.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#56A64B", "value": null }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(nephoran_intent_created_total)",
          "legendFormat": "Total",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Intent Success Rate",
      "description": "Proportion of completed intents by result (completed vs failed).",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "completed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "expr": "sum by (result) (nephoran_intent_completed_total)",
          "legendFormat": "{{result}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Intents Created per Minute",
      "description": "Rate of intent creation over time, broken down by source.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "intents/min",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "cpm"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (source) (rate(nephoran_intent_created_total[5m]) * 60)",
          "legendFormat": "{{source}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "E2 KPM Metrics",
      "type": "row"
    },
    {
      "id": 5,
      "title": "PRB Usage per Cell",
      "description": "Current Physical Resource Block usage percentage per cell. Threshold at 80% triggers scale-out evaluation.",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "nephoran_e2kpm_prb_usage_percent",
          "legendFormat": "{{gnb_id}} / {{cell_id}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "title": "PRB Usage Over Time",
      "description": "Time series of PRB usage per cell. The dashed threshold line at 80% shows the closed-loop trigger point.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "PRB %",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "#F2495C", "value": 80 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "nephoran_e2kpm_prb_usage_percent",
          "legendFormat": "{{gnb_id}} / {{cell_id}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Scale Actions",
      "description": "Count of scale_out and scale_in actions per component.",
      "type": "barchart",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "actions",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*scale_out.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*scale_in.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "expr": "sum by (component, action) (increase(nephoran_scale_actions_total[1h]))",
          "legendFormat": "{{component}} {{action}}",
          "refId": "A",
          "editorMode": "code",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "title": "Pipeline Performance",
      "type": "row"
    },
    {
      "id": 8,
      "title": "Stage Duration Heatmap",
      "description": "Distribution of pipeline stage durations as a heatmap. Each column is a time bucket; color intensity shows request density.",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": { "type": "log", "log": 2 }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": {},
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "#73BF69",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Spectral",
          "steps": 128
        },
        "filterValues": { "le": 1e-9 },
        "rowsFrame": { "layout": "auto" },
        "showValue": "never",
        "tooltip": { "mode": "single", "showColorScale": true },
        "yAxis": {
          "axisLabel": "Duration",
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "sum by (le, stage) (rate(nephoran_pipeline_stage_duration_seconds_bucket[5m]))",
          "legendFormat": "{{le}}",
          "refId": "A",
          "editorMode": "code",
          "format": "heatmap",
          "range": true
        }
      ]
    },
    {
      "id": 9,
      "title": "P95 Latency per Stage",
      "description": "95th percentile latency for each pipeline stage: planning, validating, generating, executing.",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 7, "x": 10, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "mappings": [],
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 5 },
              { "color": "#F2495C", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "orientation": "vertical",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "xTickLabelRotation": -45
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(nephoran_pipeline_stage_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}",
          "refId": "A",
          "editorMode": "code",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Pipeline Throughput",
      "description": "Rate of intent completions per minute, broken down by result.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 7, "x": 17, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "completions/min",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "cpm"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "completed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(nephoran_intent_completed_total[5m]) * 60)",
          "legendFormat": "{{result}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "GitOps & Porch",
      "type": "row"
    },
    {
      "id": 11,
      "title": "Porch Lifecycle Transitions",
      "description": "Count of Porch PackageRevision lifecycle transitions: Draft, Proposed, Published.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "transitions/min",
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "cpm"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Draft" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#8AB8FF", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Proposed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Published" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (lifecycle) (rate(nephoran_porch_lifecycle_total[5m]) * 60)",
          "legendFormat": "{{lifecycle}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    },
    {
      "id": 12,
      "title": "Git Commits Rate",
      "description": "Rate of Git commits generated by the closed-loop pipeline. Tracks the GitOps output cadence.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#5794F2", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "commits/min",
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "cpm"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(nephoran_git_commits_total[5m]) * 60)",
          "legendFormat": "Git commits (from completed intents)",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["nephoran", "m7", "closed-loop", "o-ran", "gitops"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "7d"]
  },
  "timezone": "browser",
  "title": "Nephoran M7 Closed-Loop Pipeline",
  "uid": "nephoran-m7-closed-loop",
  "version": 1,
  "weekStart": ""
}
